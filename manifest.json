{
  "manifest_version": 3,
  "name": "ÅMP-r",
  "version": "0.4",
  "description": "Ampli Rossel",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://api.github.com/repos/hugo-rossel/amp-r/releases/latest"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ÅMP-r Control Panel",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.slgnt.eu/*", "*://rossel.emsecure.net/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    },
    {
      "matches": [
        "*://*.lesoir.be/*",
        "*://*.sudinfo.be/*",
        "*://*.rossel.fr/*",
        "*://*.rossel.be/*",
        "*://*.liberation-champagne.fr/*",
        "*://*.lest-eclair.fr/*",
        "*://*.lardennais.fr/*",
        "*://*.lunion.fr/*",
        "*://*.courrier-picard.fr/*",
        "*://*.paris-normandie.fr/*",
        "*://*.aisnenouvelle.fr/*",
        "*://*.lavoixdunord.fr/*",
        "*://*.lemessager.fr/*",
        "*://*.nordlittoral.fr/*",
        "*://*.grenzecho.net/*"
      ],
      "js": ["sentinelBridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.lesoir.be/*",
        "*://*.sudinfo.be/*",
        "*://*.rossel.fr/*",
        "*://*.rossel.be/*",
        "*://*.liberation-champagne.fr/*",
        "*://*.lest-eclair.fr/*",
        "*://*.lardennais.fr/*",
        "*://*.lunion.fr/*",
        "*://*.courrier-picard.fr/*",
        "*://*.paris-normandie.fr/*",
        "*://*.aisnenouvelle.fr/*",
        "*://*.lavoixdunord.fr/*",
        "*://*.lemessager.fr/*",
        "*://*.nordlittoral.fr/*",
        "*://*.grenzecho.net/*"
      ],
      "js": ["sentinel.js"],
      "css": ["sentinel.css"],
      "world": "MAIN"
    },
    {
      "matches": ["*://stmarketingprdfc001.blob.core.windows.net/*"],
      "js": ["cdnConverter.js"],
      "run_at": "document_start"
    }
  ]
}
